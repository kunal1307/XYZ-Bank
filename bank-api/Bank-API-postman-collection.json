    {
      "name": "Overview",
      "item": [
        {
          "name": "Overview - success with token",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/overview",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "overview"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Overview contains account fields', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.accountNumber).to.exist;",
                  "    pm.expect(jsonData.accountType).to.eql('CURRENT');",
                  "    pm.expect(jsonData.currency).to.eql('EUR');",
                  "});"
                ]
              }
            }
          ]
        },
