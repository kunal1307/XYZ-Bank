    {
      "name": "Overview",
      "item": [
        {
          "name": "Overview - success",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Overview has account fields', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.accountNumber).to.exist;",
                  "    pm.expect(jsonData.accountType).to.eql('CURRENT');",
                  "    pm.expect(jsonData.currency).to.eql('EUR');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/overview?username={{username}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "overview"
              ],
              "query": [
                {
                  "key": "username",
                  "value": "{{username}}"
                }
              ]
            },
