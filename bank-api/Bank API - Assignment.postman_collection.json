    {
      "name": "Registration",
      "item": [
        {
          "name": "Register customer - success",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Response contains username and password', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.username).to.eql(pm.variables.get('username'));",
                  "    pm.expect(jsonData.password).to.not.be.empty;",
                  "    pm.collectionVariables.set('password', jsonData.password);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Kunal\",\n  \"address\": \"Amsterdam\",\n  \"username\": \"{{username}}\",\n  \"dateOfBirth\": \"1998-05-10\",\n  \"country\": \"NL\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "register"
              ]
            },
            "description": "Registers a valid customer from NL."
          },
